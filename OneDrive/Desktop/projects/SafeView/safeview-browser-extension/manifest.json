{
  "manifest_version": 3,
  "name": "SafeView Client",
  "version": "0.1.0",
  "description": "Analyzes page images with SafeView backend and blurs explicit content.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "action": {
    "default_title": "SafeView Client",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
